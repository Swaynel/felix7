generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Identity ──────────────────────────────────────────────────────────────────

enum StaffRole {
  ADMIN
  EDITOR
}

model StaffUser {
  id            String    @id @default(cuid())
  superTokensId String    @unique
  email         String    @unique
  name          String
  role          StaffRole @default(EDITOR)
  createdAt     DateTime  @default(now())
}

model Customer {
  id            String   @id @default(cuid())
  superTokensId String?  @unique // null = guest checkout account not created yet
  email         String   @unique
  name          String?
  orders        Order[]
  createdAt     DateTime @default(now())
}

// ── Music ─────────────────────────────────────────────────────────────────────

model Release {
  id            String    @id @default(cuid())
  title         String
  slug          String    @unique
  releaseDate   DateTime
  coverArtKey   String    // Cloudinary public_id (stored in musician/covers/, public access)
  description   String?
  streamingLinks Json?    // { spotify, appleMusic, youtube, soundcloud, ... }
  tracks        Track[]
  products      Product[]
  published     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Track {
  id           String  @id @default(cuid())
  release      Release @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  releaseId    String
  title        String
  trackNumber  Int
  durationSec  Int?
  previewKey   String? // Cloudinary public_id — public audio clip (musician/previews/)
  fullFileKey  String? // Cloudinary public_id — authenticated delivery only (musician/tracks/)
}

// ── Shop ──────────────────────────────────────────────────────────────────────

enum DeliveryType {
  DIGITAL
  PHYSICAL
}

model Product {
  id           String       @id @default(cuid())
  title        String
  slug         String       @unique
  description  String?
  release      Release?     @relation(fields: [releaseId], references: [id])
  releaseId    String?
  deliveryType DeliveryType
  priceMinor   Int          // smallest currency unit — never use floats for money
  currency     String       @default("NGN")
  imageKeys    String[]     // Cloudinary public_ids (musician/merch/, public)
  variants     Variant[]
  active       Boolean      @default(true)
  createdAt    DateTime     @default(now())
}

model Variant {
  id             String      @id @default(cuid())
  product        Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId      String
  label          String      // e.g. "Medium", "Vinyl - Black", "MP3 Download"
  sku            String      @unique
  stock          Int?        // null = unlimited (always null for DIGITAL)
  digitalFileKey String?     // Cloudinary public_id — authenticated delivery (musician/tracks/)
  orderItems     OrderItem[]
}

// ── Orders ────────────────────────────────────────────────────────────────────

enum OrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum FulfillmentStatus {
  NOT_APPLICABLE // DIGITAL items — delivery is on-demand via /api/download
  UNFULFILLED
  SHIPPED
  DELIVERED
}

model Order {
  id                String            @id @default(cuid())
  customer          Customer?         @relation(fields: [customerId], references: [id])
  customerId        String?
  guestEmail        String?           // set when no Customer account
  status            OrderStatus       @default(PENDING)
  paystackReference String            @unique // idempotency key — Paystack fires webhooks multiple times
  totalMinor        Int
  currency          String            @default("NGN")
  shippingAddress   Json?             // null for all-digital carts
  items             OrderItem[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([status])
  @@index([customerId])
}

model OrderItem {
  id                String            @id @default(cuid())
  order             Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId           String
  variant           Variant           @relation(fields: [variantId], references: [id])
  variantId         String
  quantity          Int
  unitPriceMinor    Int
  deliveryType      DeliveryType
  fulfillmentStatus FulfillmentStatus @default(NOT_APPLICABLE)
  downloadCount     Int               @default(0) // audit + rate-limit hook for digital items
}

// ── Shows ─────────────────────────────────────────────────────────────────────

model Show {
  id         String   @id @default(cuid())
  date       DateTime
  venueName  String
  city       String
  country    String
  ticketUrl  String?
  soldOut    Boolean  @default(false)
  published  Boolean  @default(true)
}

// ── EPK / Press ───────────────────────────────────────────────────────────────

model PressAsset {
  id        String   @id @default(cuid())
  type      String   // "photo" | "rider" | "bio" | "video_link"
  label     String
  fileKey   String?  // Cloudinary public_id (photo → musician/press/photos/, rider → musician/riders/)
  url       String?  // for video_link type (YouTube/Vimeo embed URL)
  createdAt DateTime @default(now())
}

// ── Inquiries ─────────────────────────────────────────────────────────────────

enum InquiryType {
  BOOKING
  FAN
  PRESS
}

model Inquiry {
  id        String      @id @default(cuid())
  type      InquiryType
  name      String
  email     String
  message   String
  metadata  Json?       // type-specific extras: { venue, eventDate } for BOOKING etc.
  handled   Boolean     @default(false)
  createdAt DateTime    @default(now())
}
