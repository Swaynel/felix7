# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/musician_platform"
DIRECT_URL="postgresql://user:password@localhost:5432/musician_platform"

# ── Cloudinary ────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""          # server-only, never expose to client

# ── Paystack ─────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=""            # server-only
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY="" # safe to expose to client

# ── SuperTokens ───────────────────────────────────────────────────────────
SUPERTOKENS_CONNECTION_URI=""     # your self-hosted core URL or https://try.supertokens.io for dev
SUPERTOKENS_API_KEY=""            # optional but recommended in production

NEXT_PUBLIC_API_DOMAIN="http://localhost:3000"
NEXT_PUBLIC_WEBSITE_DOMAIN="http://localhost:3000"

# ── Admin seed (only needed when running scripts/seed-admin.ts) ───────────
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
